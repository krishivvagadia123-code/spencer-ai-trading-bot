# ─── Spencer AI backend config ───────────────────────────────────────────────
# Copy this to .env ONCE:  copy .env.example .env
# Then paste your Gemini key below. Do NOT re-copy after that — it wipes your key.

PORT=8787

# Gemini API key (for Brain analysis, news sentiment, Ask Spencer).
# Get a free key at https://aistudio.google.com  → paste it here.
# NOTE: the bot can train WITHOUT this (rule-based). Only AI features need it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Zerodha Kite (optional, paid — leave blank to use free Yahoo data) ──────
KITE_API_KEY=
KITE_API_SECRET=

# ─── Bot trading config ──────────────────────────────────────────────────────
BOT_SYMBOL=RELIANCE
BOT_BUDGET=5000

# 500ms = fast training (replays 60d of real bars quickly). 60000 = real-time.
TICK_INTERVAL_MS=500

# Real Yahoo intraday bars for training
BOT_INTERVAL=5m
BOT_RANGE=60d
REPLAY_WARMUP=120

# Learning phase: pause entries 20 min after 5 consecutive losses
LEARNING_PAUSE_MS=1200000

# Paper-training switches (no real money). Keep these true to let the bot train.
ALLOW_SIMULATED_TRADING=true
ALLOW_RULE_ONLY_TRADING=true
REQUIRE_AI_APPROVAL=false
MIN_BARS_BETWEEN_TRADES=5

# Auto-start the bot when the backend boots (so `npm start` just works)
AUTO_START_BOT=true
